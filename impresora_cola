import tkinter as tk
from tkinter import messagebox
import threading
import time

class Documento:
    def __init__(self, nombre, paginas, tiempo_pagina):
        self.nombre = nombre
        self.paginas = paginas
        self.tiempo_pagina = tiempo_pagina

class ColaImpresion:
    def __init__(self):
        self.items = []
        self.lock = threading.Lock()
# Previene condiciones de carrera entre hilos

    def encolar(self, item):
        with self.lock:
            self.items.append(item)

    def desencolar(self):
        with self.lock:
            if not self.esta_vacia():
                return self.items.pop(0) # FIFO: Sale el índice 0
            return None

    def esta_vacia(self):
        return len(self.items) == 0

    def obtener_nombres(self):
        return [doc.nombre for doc in self.items]

class AppImpresora:
    def __init__(self, root):
        self.root = root
        self.root.title("Simulador de Impresión (Cola)")
        self.cola = ColaImpresion()
        self.imprimiendo = False
        self.hilo_activo = False

        self.configurar_interfaz()

    def configurar_interfaz(self):
        tk.Label(self.root, text="Nombre del Documento:").grid(row=0, column=0)
        self.entrada_nombre = tk.Entry(self.root)
        self.entrada_nombre.grid(row=0, column=1)

        tk.Label(self.root, text="Número de Páginas:").grid(row=1, column=0)
        self.entrada_paginas = tk.Entry(self.root)
        self.entrada_paginas.grid(row=1, column=1)

        tk.Label(self.root, text="Tiempo por página (s):").grid(row=2, column=0)
        self.entrada_tiempo = tk.Entry(self.root)
        self.entrada_tiempo.grid(row=2, column=1)

        tk.Button(self.root, text="Agregar a Cola", command=self.agregar_documento).grid(row=3, column=0, columnspan=2, pady=5)
        
        self.btn_iniciar = tk.Button(self.root, text="Iniciar Impresión", command=self.iniciar_simulacion)
        self.btn_iniciar.grid(row=4, column=0, columnspan=2, pady=5)

        self.lbl_estado = tk.Label(self.root, text="Estado: Esperando... No hay documentos en cola", fg="blue")
        self.lbl_estado.grid(row=5, column=0, columnspan=2, pady=10)
        
        self.lbl_cola = tk.Label(self.root, text="Cola: []")
        self.lbl_cola.grid(row=6, column=0, columnspan=2)

    def agregar_documento(self):
        nombre = self.entrada_nombre.get()
        try:
            paginas = int(self.entrada_paginas.get())
            tiempo = float(self.entrada_tiempo.get())
            if paginas <= 0 or tiempo <= 0:
                raise ValueError
        except ValueError:
            messagebox.showerror("Error", "Páginas y tiempo deben ser números positivos.")
            return

        nuevo_doc = Documento(nombre, paginas, tiempo)
        self.cola.encolar(nuevo_doc)
        self.actualizar_interfaz_cola()
        
        self.entrada_nombre.delete(0, tk.END)
        self.entrada_paginas.delete(0, tk.END)
        self.entrada_tiempo.delete(0, tk.END)

    def actualizar_interfaz_cola(self):
        self.lbl_cola.config(text=f"Cola de espera: {self.cola.obtener_nombres()}")

    def iniciar_simulacion(self):
        if not self.hilo_activo:
            self.hilo_activo = True
            hilo = threading.Thread(target=self.procesar_cola, daemon=True)
            hilo.start()
            self.btn_iniciar.config(state=tk.DISABLED)

    def procesar_cola(self):
        while True:
            if not self.cola.esta_vacia():
                doc_actual = self.cola.desencolar()
                self.actualizar_interfaz_cola()
                
                for pagina in range(1, doc_actual.paginas + 1):
                    # Uso root.after o métodos seguros para actualizar GUI desde un hilo secundario
                    mensaje = f"Imprimiendo: {doc_actual.nombre} | Página {pagina} de {doc_actual.paginas}"
                    self.lbl_estado.config(text=mensaje, fg="red")
                    time.sleep(doc_actual.tiempo_pagina) # Simula el tiempo SIN congelar Tkinter
                
            else:
                self.lbl_estado.config(text="Estado: No hay documentos en cola.", fg="blue")
                time.sleep(0.5) # Evita consumir 100% de CPU en el bucle
