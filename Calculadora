import math

class Calculadora:
    def __init__(self):
        self.resultado = None 

    def obtener_resultado_inicial(self):
        if self.resultado is None:
            self.resultado = float(input("Digite el número inicial: "))

    def suma(self, a, b): 
        return a + b
    
    def resta(self, a, b): 
        return a - b
    
    def multiplicacion(self, a, b):
        return a * b
    
    def division(self, a, b): 
        if b == 0:
            print("Error: No se puede dividir por cero")
            return a  # Devolvemos 'a' (el valor original) para no dañar el acumulado
        
        return a / b
       
    def seno(self, angulo): 
        return math.sin(math.radians(angulo))

    def coseno(self, angulo): 
        return math.cos(math.radians(angulo))
    
    def tangente(self, angulo): 
        return math.tan(math.radians(angulo))
    
    def raiz(self, numero, indice):
        if indice == 0: 
            print("Error: Índice 0")
            return a
        if numero < 0 and indice % 2 == 0: 
            print ("Error: raíz par de negativo")
            return a
        return numero ** (1 / indice)
    
    def potencia(self, base, exponente): 
        return base ** exponente
    
    def factorial(self, n):
        if n < 0: return "Error: factorial negativo"
        if n in (0,1): return 1
        return n * self.factorial(n-1)
    
    def mcd(self, a, b):
        while b: a, b = b, a % b
        return a
    
    def mcm(self, a, b): 
        return 0 if ab==0 else (ab)//self.mcd(a,b)
    
    def iva(self, valor, porcentaje): 
        return valor * (porcentaje/100)
    
    def fibonacci(self, n):
        if n < 0: return "Error: Fibonacci negativo"
        if n <= 1: return n
        return self.fibonacci(n-1)+self.fibonacci(n-2)

    def menu(self):
        while True:
            print('\n===== CALCULADORA =====')
            print("Resultado actual:", self.resultado)
            print('[1] Sumar')
            print('[2] Restar')
            print('[3] Multiplicar')
            print('[4] Dividir')
            print('[5] Seno')
            print('[6] Coseno')
            print('[7] Tangente')
            print('[8] Raíz')
            print('[9] Potencia')
            print('[10] Factorial')
            print('[11] MCM')
            print('[12] MCD')
            print('[13] IVA')
            print('[14] Fibonacci')
            print('[15] Borrar Dato Guardado')            
            print('[0] Salir')

            opcion = int(input('Seleccione la operación: '))

            match opcion:
                case 0:
                    print("Saliendo...")
                    break

                case 1:
                    self.obtener_resultado_inicial()
                    n = float(input('Número a sumar: '))
                    self.resultado = self.suma(self.resultado, n)

                case 2:
                    self.obtener_resultado_inicial()
                    n = float(input('Número a restar: '))
                    self.resultado = self.resta(self.resultado, n)

                case 3:
                    self.obtener_resultado_inicial()
                    n = float(input('Número a multiplicar: '))
                    self.resultado = self.multiplicacion(self.resultado, n)

                case 4:
                    self.obtener_resultado_inicial()
                    n = float(input('Divisor: '))
                    self.resultado = self.division(self.resultado, n)

                case 5:
                    self.obtener_resultado_inicial()
                    self.resultado = self.seno(self.resultado)

                case 6:
                    self.obtener_resultado_inicial()
                    self.resultado = self.coseno(self.resultado)

                case 7:
                    self.obtener_resultado_inicial()
                    self.resultado = self.tangente(self.resultado)

                case 8:
                    self.obtener_resultado_inicial()
                    indice = int(input('Índice de la raíz: '))
                    self.resultado = self.raiz(self.resultado, indice)

                case 9:
                    self.obtener_resultado_inicial()
                    exp = float(input('Exponente: '))
                    self.resultado = self.potencia(self.resultado, exp)

                case 10:
                    self.obtener_resultado_inicial()
                    self.resultado = self.factorial(int(self.resultado))
                case 11:
                    self.obtener_resultado_inicial()
                    n = int(input('Otro número para MCM: '))
                    self.resultado = self.mcm(int(self.resultado), n)

                case 12:
                    self.obtener_resultado_inicial()
                    n = int(input('Otro número para MCD: '))
                    self.resultado = self.mcd(int(self.resultado), n)

                case 13:
                    self.obtener_resultado_inicial()
                    porcentaje = float(input('Porcentaje de IVA: '))
                    self.resultado = self.iva(self.resultado, porcentaje)

                case 14:
                    self.obtener_resultado_inicial()
                    self.resultado = self.fibonacci(int(self.resultado))

                case 15:
                    self.obtener_resultado_inicial()
                    self.resultado = None                     
                    
                case _:
                    print("Opción no válida")

            print("Nuevo resultado:", self.resultado)

calc = Calculadora()
calc.menu()
